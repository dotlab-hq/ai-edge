{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "proxy": {
      "description": "URL of the proxy server to forward requests to",
      "type": "string",
      "format": "uri"
    },
    "$schema": {
      "type": "string",
      "format": "uri",
      "description": "URL to the JSON Schema that this configuration adheres to"
    },
    "state-adapter": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "redis",
            "memory"
          ]
        },
        {
          "type": "object",
          "properties": {
            "redis_url": {
              "type": "string",
              "format": "uri",
              "description": "Redis connection URL"
            }
          },
          "required": [
            "redis_url"
          ],
          "additionalProperties": false
        }
      ],
      "description": "Storage backend for state management - redis, memory, or { redis_url: string }"
    },
    "rateLimit": {
      "description": "Global rate limit applied to all models unless individualLimit is true",
      "type": "object",
      "properties": {
        "tokensPerMinute": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "requestsPerMinute": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "requestsPerDay": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "additionalProperties": false
    },
    "tools": {
      "description": "Optional built-in proxy tools such as web search",
      "type": "object",
      "properties": {
        "webSearch": {
          "description": "Optional built-in web search providers used to satisfy OpenAI and Anthropic web search tool requests",
          "type": "object",
          "properties": {
            "tools": {
              "minItems": 1,
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "tavily",
                      "exa"
                    ]
                  },
                  "apiKey": {
                    "type": "string",
                    "minLength": 1
                  },
                  "rateLimit": {
                    "type": "object",
                    "properties": {
                      "requestsPerMinute": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      },
                      "requestsPerDay": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      },
                      "requestsPerMonth": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type",
                  "apiKey"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "tools"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "models": {
      "type": "object",
      "properties": {
        "openai": {
          "description": "OpenAI provider configurations. If omitted, no OpenAI models will be available",
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "models": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "model": {
                          "type": "string",
                          "minLength": 1
                        },
                        "rateLimit": {
                          "type": "object",
                          "properties": {
                            "tokensPerMinute": {
                              "type": "integer",
                              "exclusiveMinimum": 0,
                              "maximum": 9007199254740991
                            },
                            "requestsPerMinute": {
                              "type": "integer",
                              "exclusiveMinimum": 0,
                              "maximum": 9007199254740991
                            },
                            "requestsPerDay": {
                              "type": "integer",
                              "exclusiveMinimum": 0,
                              "maximum": 9007199254740991
                            }
                          },
                          "additionalProperties": false
                        }
                      },
                      "required": [
                        "model",
                        "rateLimit"
                      ],
                      "additionalProperties": false
                    }
                  ]
                }
              },
              "imageModels": {
                "description": "If true, all models provided by this provider are for image operations only. Use { image_generation, image_editing } to control per-endpoint routing.",
                "anyOf": [
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "image_generation": {
                        "type": "boolean"
                      },
                      "image_editing": {
                        "type": "boolean"
                      }
                    },
                    "additionalProperties": false
                  }
                ]
              },
              "embeddings": {
                "default": false,
                "description": "If true, this provider supports embeddings endpoint",
                "type": "boolean"
              },
              "individualLimit": {
                "default": false,
                "type": "boolean"
              },
              "baseUrl": {
                "type": "string",
                "format": "uri"
              },
              "apiKey": {
                "type": "string",
                "minLength": 1
              },
              "rateLimit": {
                "type": "object",
                "properties": {
                  "tokensPerMinute": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "requestsPerMinute": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "requestsPerDay": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "additionalProperties": false
              },
              "randomRouting": {
                "default": false,
                "description": "If true, when this provider is selected it may route to any model the provider advertises at random",
                "type": "boolean"
              }
            },
            "required": [
              "id",
              "name",
              "models",
              "embeddings",
              "individualLimit",
              "baseUrl",
              "apiKey",
              "randomRouting"
            ],
            "additionalProperties": false
          }
        },
        "anthropic": {
          "description": "Anthropic provider configurations. If omitted, no Anthropic models will be available",
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "models": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "model": {
                          "type": "string",
                          "minLength": 1
                        },
                        "rateLimit": {
                          "type": "object",
                          "properties": {
                            "tokensPerMinute": {
                              "type": "integer",
                              "exclusiveMinimum": 0,
                              "maximum": 9007199254740991
                            },
                            "requestsPerMinute": {
                              "type": "integer",
                              "exclusiveMinimum": 0,
                              "maximum": 9007199254740991
                            },
                            "requestsPerDay": {
                              "type": "integer",
                              "exclusiveMinimum": 0,
                              "maximum": 9007199254740991
                            }
                          },
                          "additionalProperties": false
                        }
                      },
                      "required": [
                        "model",
                        "rateLimit"
                      ],
                      "additionalProperties": false
                    }
                  ]
                }
              },
              "individualLimit": {
                "default": false,
                "type": "boolean"
              },
              "baseUrl": {
                "type": "string",
                "format": "uri"
              },
              "apiKey": {
                "type": "string",
                "minLength": 1
              },
              "rateLimit": {
                "type": "object",
                "properties": {
                  "tokensPerMinute": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "requestsPerMinute": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "requestsPerDay": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "additionalProperties": false
              },
              "randomRouting": {
                "default": false,
                "description": "If true, when this provider is selected it may route to any model the provider advertises at random",
                "type": "boolean"
              }
            },
            "required": [
              "id",
              "name",
              "models",
              "individualLimit",
              "baseUrl",
              "apiKey",
              "randomRouting"
            ],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "$schema",
    "state-adapter",
    "models"
  ],
  "additionalProperties": false
}