{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "proxy": {
      "description": "URL of the proxy server to forward requests to",
      "type": "string",
      "format": "uri"
    },
    "spoofer": {
      "default": false,
      "description": "If true, randomly generated IP spoofing headers (X-Forwarded-For, X-Real-IP, CF-Connecting-IP, etc.) are added to every upstream request",
      "type": "boolean"
    },
    "$schema": {
      "type": "string",
      "format": "uri",
      "description": "URL to the JSON Schema that this configuration adheres to"
    },
    "state-adapter": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "redis",
            "memory"
          ]
        },
        {
          "type": "object",
          "properties": {
            "redis_url": {
              "type": "string",
              "format": "uri",
              "description": "Redis connection URL"
            }
          },
          "required": [
            "redis_url"
          ],
          "additionalProperties": false
        }
      ],
      "description": "Storage backend for state management - redis, memory, or { redis_url: string }"
    },
    "rateLimit": {
      "description": "Global rate limit applied to all models unless individualLimit is true",
      "type": "object",
      "properties": {
        "tokensPerMinute": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "requestsPerMinute": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "requestsPerDay": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "audioSecondsPerHour": {
          "description": "Maximum seconds of audio that can be processed per hour (STT)",
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "audioSecondsPerDay": {
          "description": "Maximum seconds of audio that can be processed per day (STT)",
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "tokensPerDay": {
          "description": "Maximum tokens per day",
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "additionalProperties": false
    },
    "storage": {
      "description": "Storage backend for skills and files — requires MongoDB for metadata and S3-compatible object storage for content",
      "type": "object",
      "properties": {
        "mongo_uri": {
          "type": "string",
          "minLength": 1,
          "description": "MongoDB connection URI for skills, skill versions, and file metadata (e.g. mongodb://localhost:27017)"
        },
        "s3": {
          "type": "object",
          "properties": {
            "endpoint": {
              "type": "string",
              "minLength": 1,
              "description": "S3-compatible endpoint URL (e.g. https://s3.amazonaws.com or http://minio:9000)"
            },
            "region": {
              "default": "auto",
              "description": "AWS region for S3 (default auto for S3-compatible services like MinIO)",
              "type": "string"
            },
            "access_key": {
              "type": "string",
              "minLength": 1,
              "description": "S3 access key ID"
            },
            "secret_key": {
              "type": "string",
              "minLength": 1,
              "description": "S3 secret access key"
            },
            "bucket": {
              "type": "string",
              "minLength": 1,
              "description": "S3 bucket name for skill and file storage"
            },
            "path_style": {
              "default": false,
              "description": "Use path-style S3 URLs (true for MinIO, false for AWS)",
              "type": "boolean"
            }
          },
          "required": [
            "endpoint",
            "region",
            "access_key",
            "secret_key",
            "bucket",
            "path_style"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "mongo_uri",
        "s3"
      ],
      "additionalProperties": false
    },
    "tools": {
      "description": "Optional built-in proxy tools such as web search",
      "type": "object",
      "properties": {
        "webSearch": {
          "description": "Optional built-in web search providers used to satisfy OpenAI and Anthropic web search tool requests",
          "type": "object",
          "properties": {
            "tools": {
              "minItems": 1,
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "tavily",
                      "exa"
                    ]
                  },
                  "apiKey": {
                    "type": "string",
                    "minLength": 1
                  },
                  "rateLimit": {
                    "type": "object",
                    "properties": {
                      "requestsPerMinute": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      },
                      "requestsPerDay": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      },
                      "requestsPerMonth": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      }
                    },
                    "additionalProperties": false
                  },
                  "timeoutMs": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "options": {
                    "type": "object",
                    "properties": {
                      "maxResults": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      },
                      "searchDepth": {
                        "type": "string",
                        "enum": [
                          "basic",
                          "advanced"
                        ]
                      },
                      "includeRawContent": {
                        "type": "boolean"
                      },
                      "includeAnswer": {
                        "type": "boolean"
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": [
                  "type",
                  "apiKey"
                ],
                "additionalProperties": false
              }
            },
            "defaults": {
              "type": "object",
              "properties": {
                "maxResults": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "expandQueries": {
                  "type": "boolean"
                },
                "maxExpandedQueries": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "parallelQueries": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "softTimeoutMs": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "providerTimeoutMs": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                }
              },
              "additionalProperties": false
            }
          },
          "required": [
            "tools"
          ],
          "additionalProperties": false
        },
        "code_interpreter": {
          "description": "Alias for codeInterpreter (optional code interpreter provider)",
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "daytona"
              ]
            },
            "apiKey": {
              "type": "string",
              "minLength": 1
            },
            "apiUrl": {
              "type": "string",
              "format": "uri"
            },
            "language": {
              "type": "string",
              "enum": [
                "python",
                "typescript",
                "javascript"
              ]
            },
            "timeout": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "target": {
              "type": "string",
              "enum": [
                "us",
                "eu"
              ]
            },
            "image": {
              "type": "string",
              "minLength": 1
            },
            "snapshot": {
              "type": "string",
              "minLength": 1
            },
            "resources": {
              "type": "object",
              "properties": {
                "cpu": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "memory": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "disk": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                }
              },
              "additionalProperties": false
            },
            "autoStopInterval": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "labels": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {
                "type": "string"
              }
            },
            "initialFiles": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "required": [
            "type",
            "apiKey"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "vectorStore": {
      "description": "Vector store proxy configuration — forwards /v1/vector_stores and /v1/files requests to the target. Check out https://github.com/dotlab-hq/vector-store! :)",
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Base URL of the vector store API to proxy requests to"
        },
        "apiKey": {
          "type": "string",
          "minLength": 1,
          "description": "API key sent as Authorization header to the vector store"
        }
      },
      "required": [
        "url",
        "apiKey"
      ],
      "additionalProperties": false
    },
    "realtime": {
      "description": "Realtime API proxy configuration — forwards /v1/realtime requests to the target endpoint",
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Base URL of the OpenAI Realtime API to proxy requests to (e.g. https://api.openai.com/v1)"
        },
        "apiKey": {
          "type": "string",
          "minLength": 1,
          "description": "API key sent as Authorization header to the Realtime API"
        }
      },
      "required": [
        "url",
        "apiKey"
      ],
      "additionalProperties": false
    },
    "models": {
      "type": "object",
      "properties": {
        "openai": {
          "description": "OpenAI provider configurations. If omitted, no OpenAI models will be available",
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "models": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "model": {
                          "type": "string",
                          "minLength": 1
                        },
                        "rateLimit": {
                          "type": "object",
                          "properties": {
                            "tokensPerMinute": {
                              "type": "integer",
                              "exclusiveMinimum": 0,
                              "maximum": 9007199254740991
                            },
                            "requestsPerMinute": {
                              "type": "integer",
                              "exclusiveMinimum": 0,
                              "maximum": 9007199254740991
                            },
                            "requestsPerDay": {
                              "type": "integer",
                              "exclusiveMinimum": 0,
                              "maximum": 9007199254740991
                            },
                            "audioSecondsPerHour": {
                              "description": "Maximum seconds of audio that can be processed per hour (STT)",
                              "type": "integer",
                              "exclusiveMinimum": 0,
                              "maximum": 9007199254740991
                            },
                            "audioSecondsPerDay": {
                              "description": "Maximum seconds of audio that can be processed per day (STT)",
                              "type": "integer",
                              "exclusiveMinimum": 0,
                              "maximum": 9007199254740991
                            },
                            "tokensPerDay": {
                              "description": "Maximum tokens per day",
                              "type": "integer",
                              "exclusiveMinimum": 0,
                              "maximum": 9007199254740991
                            }
                          },
                          "additionalProperties": false
                        },
                        "modalities": {
                          "default": {
                            "input": [
                              "text",
                              "image",
                              "audio",
                              "file"
                            ],
                            "output": [
                              "text"
                            ]
                          },
                          "description": "Modalities this provider or model supports. Used for the model listing endpoint.",
                          "type": "object",
                          "properties": {
                            "input": {
                              "default": [
                                "text",
                                "image",
                                "audio",
                                "file"
                              ],
                              "description": "Input modalities this provider or model accepts",
                              "minItems": 1,
                              "type": "array",
                              "items": {
                                "type": "string",
                                "enum": [
                                  "text",
                                  "image",
                                  "audio",
                                  "file",
                                  "pdf"
                                ]
                              }
                            },
                            "output": {
                              "default": [
                                "text"
                              ],
                              "description": "Output modalities this provider or model can produce",
                              "minItems": 1,
                              "type": "array",
                              "items": {
                                "type": "string",
                                "enum": [
                                  "text",
                                  "audio"
                                ]
                              }
                            }
                          },
                          "required": [],
                          "additionalProperties": false
                        },
                        "reasoning_efforts": {
                          "description": "Reasoning effort levels explicitly supported by this provider or model. Omit this field to disable proxy-injected reasoning defaults.",
                          "minItems": 1,
                          "type": "array",
                          "items": {
                            "type": "string",
                            "enum": [
                              "none",
                              "low",
                              "medium",
                              "high",
                              "xhigh",
                              "max"
                            ]
                          }
                        },
                        "default_reasoning": {
                          "description": "Default reasoning effort used only when reasoning is explicitly configured for this provider or model.",
                          "type": "string",
                          "enum": [
                            "none",
                            "low",
                            "medium",
                            "high",
                            "xhigh",
                            "max"
                          ]
                        }
                      },
                      "required": [
                        "model",
                        "rateLimit"
                      ],
                      "additionalProperties": false
                    }
                  ]
                }
              },
              "modalities": {
                "default": {
                  "input": [
                    "text",
                    "image",
                    "audio",
                    "file"
                  ],
                  "output": [
                    "text"
                  ]
                },
                "description": "Modalities this provider or model supports. Used for the model listing endpoint.",
                "type": "object",
                "properties": {
                  "input": {
                    "default": [
                      "text",
                      "image",
                      "audio",
                      "file"
                    ],
                    "description": "Input modalities this provider or model accepts",
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "text",
                        "image",
                        "audio",
                        "file",
                        "pdf"
                      ]
                    }
                  },
                  "output": {
                    "default": [
                      "text"
                    ],
                    "description": "Output modalities this provider or model can produce",
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "text",
                        "audio"
                      ]
                    }
                  }
                },
                "required": [],
                "additionalProperties": false
              },
              "imageModels": {
                "description": "Provider image routing flags. Explicitly set image_generation and/or image_editing to enable those endpoints.",
                "type": "object",
                "properties": {
                  "image_generation": {
                    "type": "boolean"
                  },
                  "image_editing": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": false
              },
              "embeddings": {
                "default": false,
                "description": "If true, this provider is reserved for embeddings routing and excluded from chat/completions/responses fallback",
                "type": "boolean"
              },
              "stt": {
                "default": false,
                "description": "If true, this provider is reserved for speech-to-text routing (audio/transcriptions, audio/translations) and excluded from chat/completions/responses/embeddings fallback",
                "type": "boolean"
              },
              "tts": {
                "default": false,
                "description": "If true, this provider is reserved for text-to-speech routing (audio/speech) and excluded from chat/completions/responses/embeddings fallback",
                "type": "boolean"
              },
              "PII_Rampart": {
                "default": true,
                "description": "Apply Rampart PII protection to text-generation requests and responses only; excluded from image, audio, and vector-store routes",
                "type": "boolean"
              },
              "individualLimit": {
                "default": false,
                "type": "boolean"
              },
              "baseUrl": {
                "type": "string",
                "format": "uri"
              },
              "apiKey": {
                "type": "string",
                "minLength": 1
              },
              "rateLimit": {
                "type": "object",
                "properties": {
                  "tokensPerMinute": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "requestsPerMinute": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "requestsPerDay": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "audioSecondsPerHour": {
                    "description": "Maximum seconds of audio that can be processed per hour (STT)",
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "audioSecondsPerDay": {
                    "description": "Maximum seconds of audio that can be processed per day (STT)",
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "tokensPerDay": {
                    "description": "Maximum tokens per day",
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "additionalProperties": false
              },
              "randomRouting": {
                "default": true,
                "description": "If false, disables this provider as a fallback for unknown models or exhausted exact-model providers",
                "type": "boolean"
              },
              "reasoning_efforts": {
                "description": "Reasoning effort levels explicitly supported by this provider or model. Omit this field to disable proxy-injected reasoning defaults.",
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "none",
                    "low",
                    "medium",
                    "high",
                    "xhigh",
                    "max"
                  ]
                }
              },
              "default_reasoning": {
                "description": "Default reasoning effort used only when reasoning is explicitly configured for this provider or model.",
                "type": "string",
                "enum": [
                  "none",
                  "low",
                  "medium",
                  "high",
                  "xhigh",
                  "max"
                ]
              }
            },
            "required": [
              "id",
              "name",
              "models",
              "embeddings",
              "stt",
              "tts",
              "PII_Rampart",
              "individualLimit",
              "baseUrl",
              "apiKey",
              "randomRouting"
            ],
            "additionalProperties": false
          }
        },
        "anthropic": {
          "description": "Anthropic provider configurations. If omitted, no Anthropic models will be available",
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
